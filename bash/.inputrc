# Never ring any sort of bell.
set bell-style none

# Only prompt when there are more than this many completion candidates.
set completion-query-items 200

# List ambiguous matches immediately without ringing the bell.
set show-all-if-ambiguous on

# Immediately add a trailing slash when autocompleting symlinks to directories.
set mark-symlinked-directories on

# Require an explicit '.' in order to match hidden files.
set match-hidden-files off

# Be more intelligent when autocompleting by also looking at the text after
# the cursor. (This is supported by the Readline used by Bash 4.)
set skip-completed-text on

# Show extra file information when completing, like `ls -F` does.
set visible-stats on

# Allow UTF-8 input and output, instead of showing stuff like $'\0123\0456'.
set input-meta on
set output-meta on
set convert-meta off

# Let Readline ignore the TTY's special-char bindings (Bash 4.4+).
set bind-tty-special-chars off

Control-d:  possible-completions
Control-w:  backward-kill-word

"\e[A":     history-search-backward # Up
"\e[B":     history-search-forward  # Down
"\e[1;5D":  backward-word           # Ctrl+Left
"\e[1;5C":  forward-word            # Ctrl+Right
"\e\e[D":   backward-word           # Alt+Left
"\e\e[C":   forward-word            # Alt+Right

$if Bash
    space: magic-space
$endif
